# --- Python Artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env

# --- Large Models & Binaries (Auto-downloaded) ---
# Ignore the Piper TTS folder (it's huge and OS-specific)
piper/

# Ignore large model files
*.onnx
*.bin
*.tflite

# Exception: Un-comment the line below if you WANT to share your custom wake word
# !wakeword.onnx

# --- User Configuration & Memory ---
# Keep chat history local (Privacy)
memory.json
chat_memory.json

# Visitor log can contain real visitor/host names — keep it on-device only
visitor_log.jsonl

# Secrets (SMTP password, M365 client secret, web UI password hash).
# Deep-merged over config.json at runtime; never commit real values.
secrets.json

# M365 directory cache (synced from Microsoft Graph; may list staff)
m365_directory.json

# Visitor check-in photos (faces are PII; kept on-device only)
visitor_photos/

# Per-device settings (audio devices, wake model, branding, phrases, etc.).
# Tracked template is config.example.json; each device keeps its own config.json.
config.json

# Per-site staff directory (real names/contacts). Template: employees.example.json
employees.json

# --- Temporary/Generated Media ---
*.wav
*.mp3
*.jpg
*.png
camera_capture.jpg
current_image.jpg
test_audio.wav

# --- Cloned deps / downloaded models (provided by setup.sh) ---
whisper.cpp/
voices/

# --- Local backups & logs ---
*.bak
*.bak.*
*.log

# --- OS Generated Files ---
.DS_Store
Thumbs.db
ehthumbs.db
preview_faces/
